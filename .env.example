# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration (use MongoDB Atlas connection string on Vercel)
MONGODB_URI=mongodb://localhost:27017/ointment-booking

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# CORS — on Vercel set to your production origin, e.g. https://your-project.vercel.app
# CORS_ORIGIN=http://localhost:5173

# Frontend API base — leave unset for same-origin (/api). Set full URL only if API is on another host.
# VITE_API_URL=https://your-api.example.com/api
